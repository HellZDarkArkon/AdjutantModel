any - P - U - AUTO
any [DECLARATIVE] - P - U - H_PLUS_L_STAR
any [INTERROGATIVE] - P - U - L_PLUS_H_STAR
any [CONTINUATION] - P - U - L_PLUS_H_STAR
any [EXCLAMATORY] - P - U - H_STAR

